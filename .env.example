# 🛡️ SafeGuard Bot — Production Environment Variables Template

# 1. Telegram Bot Settings
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username_here        # e.g., safeguard_uz_bot (@ belgisisiz)
ADMIN_ID=your_telegram_id_here             # Bot egasining raqamli Telegram ID si

# 2. Cybersecurity Antivirus and AI Keys
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here    # Ixtiyoriy — AI NLP uchun

# 3. Majburiy Obuna Kanali
# Foydalanuvchilar /start bosganida kanalga obuna bo'lishi talab qilinadi
CHANNEL_USERNAME=@SafeGuard_news           # Kanal username (@ bilan)
CHANNEL_ID=-1001234567890                  # Kanalning raqamli ID si
# ⚠️ CHANNEL_ID ni topish: @username_to_id_bot dan foydalaning
# yoki kanalga @RawDataBot ni qo'shing va u ID ni yuboradi

# 4. Server Mode Settings (Optional for Webhooks)
# Faqat webhook rejimida deploy qilganda kerak (100k+ foydalanuvchi uchun tavsiya)
WEBHOOK_URL=https://your-app-name.onrender.com
PORT=8080

# 5. Database Path (Optional)
# Default: loyiha papkasi ichida users.db
# Render.com uchun: /var/data/users.db
# DB_PATH=/var/data/users.db
