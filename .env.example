# 🛡️ SafeGuard Bot — Production Environment Variables Template

# 1. Telegram Bot Settings
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username_here  # e.g., safeguard_uz_bot
ADMIN_ID=your_telegram_id_here       # Numeric ID of the bot owner/admin

# 2. Cybersecurity Antivirus and AI Keys
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# 3. Server Mode Settings (Optional for Webhooks)
# Set WEBHOOK_URL only if deploying in webhook mode (recommended for 100k+ users)
WEBHOOK_URL=https://your-app-name.onrender.com
PORT=8080
